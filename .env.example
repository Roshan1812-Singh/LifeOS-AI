# ============================================================
# LifeOS AI - Environment Configuration (copy to .env)
# ============================================================
# NEVER commit the real .env file. Keep secrets out of git.

# ---- PostgreSQL ----
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Backend (Spring Boot) ----
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT - generate a long random base64 secret (min 256-bit). Example:
#   openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_base64_secret_at_least_64_bytes_long_xxxxxxxxxxxx
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000        # 15 minutes
JWT_REFRESH_TOKEN_EXPIRATION_MS=1209600000   # 14 days

# CORS - comma separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- AI layer (Phase 2 - placeholders for now) ----
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small

# ---- AWS S3 compatible storage (Phase 4) ----
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=lifeos-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8080/api
