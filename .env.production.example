# ============================================================
# LifeOS AI - PRODUCTION environment (copy to .env, never commit)
# Used by docker-compose.prod.yml
# ============================================================
# Generate strong random secrets, e.g.:
#   JWT_SECRET:           openssl rand -base64 64
#   POSTGRES_PASSWORD:    openssl rand -base64 24
#   REDIS_PASSWORD:       openssl rand -base64 24
# ------------------------------------------------------------

# ---- Container images (set to your registry/owner + tag) ----
BACKEND_IMAGE=ghcr.io/your-org/lifeos-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/lifeos-frontend:latest

# ---- PostgreSQL (internal only; not published to host) ----
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password

# ---- Redis (internal only; password required) ----
REDIS_PASSWORD=__CHANGE_ME__strong_redis_password

# ---- Backend ----
# Long random base64 secret, at least 64 bytes.
JWT_SECRET=__CHANGE_ME__run_openssl_rand_base64_64
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000        # 15 minutes
JWT_REFRESH_TOKEN_EXPIRATION_MS=1209600000   # 14 days

# Comma-separated origins allowed to call the API (your real web + any apps).
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# Port the backend API is published on (the mobile app talks to this directly).
BACKEND_PORT=8080
BACKEND_MEM_LIMIT=768m

# ---- AI (optional; blank = AI features return an honest 503) ----
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ---- Storage: 'local' (volume-backed) or 's3' ----
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---- Frontend ----
# Port the web app (nginx) is published on. Put a TLS-terminating proxy in front.
WEB_PORT=80
