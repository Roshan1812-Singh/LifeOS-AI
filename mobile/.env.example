# Base URL of the LifeOS AI backend API (must end with /api).
#
# Leave unset to auto-detect during local development:
#   - Android emulator  -> http://10.0.2.2:8080/api
#   - iOS simulator     -> http://localhost:8080/api
#   - Physical device   -> http://<your-LAN-IP>:8080/api (derived from the Metro host)
#
# For real builds, point this at your deployed backend, e.g.:
# EXPO_PUBLIC_API_URL=https://api.lifeos.example.com/api
EXPO_PUBLIC_API_URL=
